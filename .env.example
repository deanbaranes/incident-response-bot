# ── Webhook Security ─────────────────────────────────────────────────────────
# HMAC-SHA256 secret shared with Grafana (Contact Point → Webhook → Secret).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If omitted, signature verification is skipped (not recommended for production).
WEBHOOK_SECRET=your_webhook_secret_here

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token or fine-grained token with repo read access
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repository that stores the playbook YAML files (owner/repo format)
GITHUB_REPO=your-org/your-repo

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# API key from Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# The Gmail address used to send incident reports
EMAIL_SENDER=alerts@example.com

# Gmail app password (not your account password — generated in Google Account → Security → App passwords)
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# SMTP server — defaults to smtp.gmail.com if omitted
EMAIL_HOST=smtp.gmail.com

# SMTP port — defaults to 587 (STARTTLS) if omitted
EMAIL_PORT=587

# Comma-separated list of recipient addresses for incident reports.
# Falls back to EMAIL_SENDER if omitted.
EMAIL_RECIPIENTS=oncall@example.com,team-lead@example.com

# ── Grafana / Prometheus ──────────────────────────────────────────────────────
# Base URL of your Grafana instance (no trailing slash)
GRAFANA_URL=https://your-org.grafana.net

# Grafana Cloud: numeric Prometheus instance ID. Self-hosted: leave blank or set username.
GRAFANA_USERNAME=123456

# Service account token with Metrics Reader role
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publicly accessible Grafana dashboard URL used for screenshots
GRAFANA_DASHBOARD_URL=https://your-org.grafana.net/d/xxxxxx/dashboard-name

# ── Playbooks ─────────────────────────────────────────────────────────────────
# Directory containing playbook YAML files. Defaults to ./playbooks (relative to project root).
# In Docker this resolves to /app/playbooks which is included in the image.
# PLAYBOOKS_DIR=/app/playbooks

# ── Webhook Security ─────────────────────────────────────────────────────────
# Optional HMAC-SHA256 secret for validating Grafana webhook signatures.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WEBHOOK_SECRET=your-secret-here
